# AI DevOps Copilot — local environment
# DO NOT commit real secrets. (Reminder: .gitignore was deferred; add it before pushing.)

# ---- Application ----
ENVIRONMENT=development
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000

# ---- LLM provider ----
# "anthropic" (requires ANTHROPIC_API_KEY) or "ollama" (local, no key required)
LLM_PROVIDER=ollama

# ---- Anthropic ----
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-7

# ---- Ollama (local model, no API key) ----
# Install: https://ollama.com/download   Then: `ollama pull llama3.1:8b`
OLLAMA_MODEL=llama3.2:3b
OLLAMA_BASE_URL=http://localhost:11434

# ---- RAG / ChromaDB (Step 4) ----
CHROMA_DB_PATH=./chroma_db
CHROMA_COLLECTION=devops_docs
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
RAG_TOP_K=4

# ---- MCP integrations (Step 5, all optional) ----
GITHUB_TOKEN=
POSTGRES_URL=
KUBECONFIG_PATH=
FILESYSTEM_ROOT=
